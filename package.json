{
  "name": "fit-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy",
    "test": "jest"
  },
  "dependencies": {
    "@clerk/expo": "^3.2.2",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "^53.0.27",
    "expo-auth-session": "~6.2.1",
    "expo-constants": "~17.1.4",
    "expo-image": "~2.4.1",
    "expo-linking": "~7.1.4",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "^0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-web-browser": "~14.2.0",
    "fuse.js": "^7.3.0",
    "groq": "^5.23.0",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.14",
    "nativewind": "^4.0.1",
    "openai": "^6.37.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "^0.79.4",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "react-timer-hook": "^4.0.5",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.14",
    "typescript": "~5.8.3"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|@react-native-async-storage|expo(nent)?|@expo(nent)?/.*|expo-modules-core|react-navigation|@react-navigation/.*|react-native-svg|nativewind|react-native-css-interop|zustand)/)"
    ]
  }
}
